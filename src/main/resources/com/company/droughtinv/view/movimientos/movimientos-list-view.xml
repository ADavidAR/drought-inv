<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://movimientosListView.title"
      focusComponent="movimientosesDataGrid">
    <data>
        <collection id="movimientosesDc"
                    class="com.company.droughtinv.entity.Movimientos">
            <fetchPlan extends="_base"/>
            <loader id="movimientosesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Movimientos e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="movimientosesDataGrid.createAction"/>
                <button id="editButton" action="movimientosesDataGrid.editAction"/>
                <button id="refreshButton" action="movimientosesDataGrid.refreshAction"/>
                <button id="removeButton" action="movimientosesDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="movimientosesDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="movimientosesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="movimientosesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="refreshAction" type="list_refresh"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="descripcion"/>
                <column property="factor"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
