<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://sucursalListView.title"
      focusComponent="sucursalsDataGrid">
    <data>
        <collection id="sucursalsDc"
                    class="com.company.droughtinv.entity.Sucursal">
            <fetchPlan extends="_base"/>
            <loader id="sucursalsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Sucursal e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="sucursalsDataGrid.createAction"/>
                <button id="editButton" action="sucursalsDataGrid.editAction"/>
                <button id="refreshButton" action="sucursalsDataGrid.refreshAction"/>
                <button id="removeButton" action="sucursalsDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="sucursalsDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="sucursalsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="sucursalsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="refreshAction" type="list_refresh"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="nombre"/>
                <column property="telefono"/>
                <column property="direccion"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
