<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://lotesListView.title"
      focusComponent="lotesesDataGrid">
    <data>
        <collection id="lotesesDc"
                    class="com.company.droughtinv.entity.Lotes">
            <fetchPlan extends="_base">
                <property name="producto" fetchPlan="_instance_name">
                    <property name="nombre"/>
                    <property name="fechaCaducacion"/>
                    <property name="precio"/>
                </property>
            </fetchPlan>
            <loader id="lotesesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Lotes e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="lotesesDataGrid.createAction"/>
                <button id="editButton" action="lotesesDataGrid.editAction"/>
                <button id="refreshButton" action="lotesesDataGrid.refreshAction"/>
                <button id="removeButton" action="lotesesDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="lotesesDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="lotesesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="lotesesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="refreshAction" type="list_refresh"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="producto"/>
                <column property="fechaElaboracion"/>
                <column property="fechaCaducidad"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
