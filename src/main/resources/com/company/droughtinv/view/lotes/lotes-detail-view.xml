<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://lotesDetailView.title"
      focusComponent="form">
    <data>
        <instance id="lotesDc"
                  class="com.company.droughtinv.entity.Lotes">
            <fetchPlan extends="_base">
                <property name="producto" fetchPlan="_instance_name">
                    <property name="nombre"/>
                    <property name="fechaCaducacion"/>
                    <property name="precio"/>
                </property>
            </fetchPlan>
            <loader id="lotesDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="lotesDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <entityPicker id="productoField" property="producto">
                <actions>
                    <action id="entityLookupAction" type="entity_lookup"/>
                    <action id="entityClearAction" type="entity_clear"/>
                </actions>
            </entityPicker>
            <datePicker id="fechaElaboracionField" property="fechaElaboracion"/>
            <datePicker id="fechaCaducidadField" property="fechaCaducidad"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
