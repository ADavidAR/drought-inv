<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://productosListView.title"
      focusComponent="productosesDataGrid">
    <data>
        <collection id="productosesDc"
                    class="com.company.droughtinv.entity.Productos">
            <fetchPlan extends="_base">
                <property name="categoria" fetchPlan="_base"/>
                <property name="proveedor" fetchPlan="_instance_name">
                    <property name="nombre"/>
                </property>
            </fetchPlan>
            <loader id="productosesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Productos e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="productosesDataGrid.createAction"/>
                <button id="editButton" action="productosesDataGrid.editAction"/>
                <button id="refreshButton" action="productosesDataGrid.refreshAction"/>
                <button id="removeButton" action="productosesDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="productosesDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="productosesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="productosesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="refreshAction" type="list_refresh"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="nombre" header="msg://column.header"/>
                <column property="descripcion" header="msg://column1.header"/>
                <column property="fechaCaducacion" header="msg://column2.header"/>
                <column property="precio" header="msg://column3.header"/>
                <column property="costo" header="Costo"/>
                <column property="categoria" header="Categoria"/>
                <column property="proveedor" header="Proveedor"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
